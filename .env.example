# Скопируй этот файл в .env и заполни своими значениями
# cp .env.example .env

# Твой user_id на polemicagame.com (видно в URL профиля)
MY_USER_ID=1382

# Сколько матчей парсить за один запуск (режим all)
SCRAPE_COUNT=10000

# Последний известный match_id (обновляется автоматически)
LAST_MATCH_ID=591399

# Задержка между запросами в секундах (0.25 — норма, 0.5 — если 429)
DELAY=0.25

# Путь к базе данных
DB_PATH=data/players.db

# Путь к выходному HTML
HTML_OUT=data/stats.html
